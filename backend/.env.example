# Local development env. Copy to `.env` (gitignored). See docs/architecture.md.

# --- App ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# --- Database ---
DATABASE_URL=postgres://arrears:arrears@localhost:5432/arrears_poc

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_SPEND_CAP_GBP_DAILY=5

# --- Outlook / Microsoft Graph (shared mailbox) ---
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_SHARED_MAILBOX=arrears-test@<lofty-tenant>

# --- Mode switches ---
# `mailhog` (default for local) or `outlook`
OUTBOUND_MODE=mailhog
# `fixtures` (read from fixtures/ on disk) or `stage`
INTEGRATION_MODE=fixtures

# --- Credential store ---
# `LOCAL` (Postgres-encrypted blobs) or `SECRETS_MANAGER` (hosted POC; not implemented yet)
CREDENTIAL_STORAGE_BACKEND=LOCAL
# Base64-encoded 32-byte key used by the LOCAL credential store (AES-256-GCM).
# Generate with: `openssl rand -base64 32`
CREDENTIAL_ENCRYPTION_KEY=

# --- Upstreams ---
LWCA_STAGE_BASE_URL=https://stage.uk.loftyworks.com
RENTANCY_STAGE_BASE_URL=https://api.stage.uk.loftyworks.com

# --- Cognito (Lofty stage pool, for refreshing upstream service-user tokens) ---
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# --- Cognito (Arrears-owned pool, for our own app auth) ---
ARREARS_COGNITO_USER_POOL_ID=
ARREARS_COGNITO_CLIENT_ID=

# --- Dev tools ---
# When set, bypasses JWT verification and pretends the request is from this user id.
DEV_AUTH_BYPASS_USER_ID=
# When true, mounts /dev/* endpoints (advance-clock, seed-fixture-emails, force-sync).
DEV_TOOLS_ENABLED=true

# --- Hard rule master switch (POC: must stay false) ---
ARREARS_AUTOSEND_ENABLED=false
